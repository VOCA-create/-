[Unit]
Description=Mapo e-Approval Web Server
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/eapproval
EnvironmentFile=/opt/eapproval/.env
ExecStart=/usr/bin/python3 /opt/eapproval/server.py --host 127.0.0.1 --port 8080
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
